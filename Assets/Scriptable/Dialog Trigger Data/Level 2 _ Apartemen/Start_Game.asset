  m_Script: {fileID: 11500000, guid: 412804b0908ab424f958263edd940644, type: 3}
  m_Name: Start_Game
  m_EditorClassIdentifier: Assembly-CSharp::HiddenResidue.Dialog.DialogData
  lines:
  - speakerName: Polisi
    text: Tempat ini sesuai dengan alamat yang kita temukan
    portrait: {fileID: 4767926918714881177, guid: 47e2d50a95ad68b47952b00e27b296c7, type: 3}
  - speakerName: Polisi
    text: "Sepertinya seseorang tinggal di sini\u2026 atau pernah"
    portrait: {fileID: 4767926918714881177, guid: 47e2d50a95ad68b47952b00e27b296c7, type: 3}
  - speakerName: Jojo
    text: "Kondisinya berantakan\u2026 seperti habis terjadi sesuatu"
    portrait: {fileID: 7618241661640986916, guid: 0b9f28f6c91cd58438f2c43baa6062dd, type: 3}
  - speakerName: Polisi
    text: Bersihkan area ini, dan cari apa pun yang mencurigakan
    portrait: {fileID: 4767926918714881177, guid: 47e2d50a95ad68b47952b00e27b296c7, type: 3}
  - speakerName: Jojo
    text: "Baik\u2026 aku akan mulai"
    portrait: {fileID: 7618241661640986916, guid: 0b9f28f6c91cd58438f2c43baa6062dd, type: 3}
