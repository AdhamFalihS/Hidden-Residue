  m_Script: {fileID: 11500000, guid: 412804b0908ab424f958263edd940644, type: 3}
  m_Name: Ask_Police
  m_EditorClassIdentifier: Assembly-CSharp::HiddenResidue.Dialog.DialogData
  lines:
  - speakerName: Jojo
    text: Pak, apa yang sebenarnya terjadi di sini?
    portrait: {fileID: 7618241661640986916, guid: 0b9f28f6c91cd58438f2c43baa6062dd, type: 3}
  - speakerName: Polisi
    text: Kami menerima laporan adanya insiden di tempat ini
    portrait: {fileID: 4767926918714881177, guid: 47e2d50a95ad68b47952b00e27b296c7, type: 3}
  - speakerName: Polisi
    text: Tapi tidak ada bukti besar yang ditemukan
    portrait: {fileID: 4767926918714881177, guid: 47e2d50a95ad68b47952b00e27b296c7, type: 3}
  - speakerName: Polisi
    text: Hanya ada beberapa tanda kecil yang terlihat mencurigakan
    portrait: {fileID: 4767926918714881177, guid: 47e2d50a95ad68b47952b00e27b296c7, type: 3}
  - speakerName: Jojo
    text: "Jadi tugas saya\u2026 membersihkan sekaligus mencari petunjuk?"
    portrait: {fileID: 7618241661640986916, guid: 0b9f28f6c91cd58438f2c43baa6062dd, type: 3}
  - speakerName: Polisi
    text: Betul. Perhatikan setiap detail sekecil apapun
    portrait: {fileID: 4767926918714881177, guid: 47e2d50a95ad68b47952b00e27b296c7, type: 3}
  - speakerName: Polisi
    text: Kadang petunjuk terbesar datang dari hal yang terlihat sepele
    portrait: {fileID: 4767926918714881177, guid: 47e2d50a95ad68b47952b00e27b296c7, type: 3}
  - speakerName: Jojo
    text: "Baik\u2026 saya akan mulai sekarang"
    portrait: {fileID: 7618241661640986916, guid: 0b9f28f6c91cd58438f2c43baa6062dd, type: 3}
